{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,

    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["bun", "node"],

    "paths": {
      "@incur-examples/connectrpc-example": ["./packages/connectrpc-example/src/index.ts"],
      "@incur-examples/connectrpc-example/user_pb": [
        "./packages/connectrpc-example/src/user_pb.ts"
      ],
      "@incur-examples/graphql-example": ["./packages/graphql-example/src/index.ts"]
    },

    "noEmit": true
  }
}
